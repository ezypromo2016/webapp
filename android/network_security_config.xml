<?xml version="1.0" encoding="utf-8"?>
<!--
  Network Security Config
  File: app/src/main/res/xml/network_security_config.xml
  Allows cleartext HTTP to local dev server (remove in production with real HTTPS)
-->
<network-security-config>
    <!-- Allow cleartext to local IP ranges (development/LAN) -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">10.0.2.2</domain>
        <domain includeSubdomains="true">192.168.0.0</domain>
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">127.0.0.1</domain>
    </domain-config>

    <!-- Production domain should use HTTPS -->
    <!-- 
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">yourproductiondomain.com</domain>
    </domain-config>
    -->
</network-security-config>
